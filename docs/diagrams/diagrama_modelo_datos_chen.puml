@startchen Modelo_Concentual_Kimun
skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #333333
skinparam shadowing false

/' ============================================
   MODELO CONCEPTUAL DE DATOS - KIMÜN LMS
   Notación Chen (Entidad-Relación)
   ============================================ '/

/' ============================================
   ENTIDADES
   ============================================ '/

/'-- USUARIOS --'/
entity AreaCargo {
    nombre
}
entity Usuario {
    rut
    username
    first_name
    last_name
    email
    rol
}
entity Recordatorio {
    tipo
    fecha_envio
}

/'-- CURSOS --'/
entity Categoria {
    nombre
    color
    descripcion
}
entity Curso {
    titulo
    descripcion
    estado
    fecha_creacion
    fecha_limite
}
entity Material {
    titulo
    tipo
    archivo
    url
}
entity Clase {
    titulo
    contenido
    orden
    fecha_creacion
}
entity InscripcionCurso {
    estado
    fecha_asignacion
}
entity ClaseCompletado {
    fecha_completado
}
entity Tarea {
    titulo
    descripcion
    fecha_limite
    puntaje_maximo
}
entity EntregaTarea {
    archivo
    comentario
    estado
    puntaje_obtenido
    retroalimentacion
}

/'-- EVALUACIONES --'/
entity Evaluacion {
    titulo
    porcentaje_aprobacion
    max_intentos
    duracion_minutos
}
entity BancoPreguntas {
    nombre
    descripcion
    es_publico
}
entity Pregunta {
    texto
}
entity Alternativa {
    texto
    es_correcta
}
entity IntentoEvaluacion {
    puntaje_obtenido
    aprobado
    fecha_intento
    respuestas
}

/'-- CERTIFICADOS --'/
entity Certificado {
    codigo_verificacion
    fecha_emision
    estado
    fecha_aprobacion
}

/'-- CALENDARIO Y ANUNCIOS --'/
entity EventoCalendario {
    titulo
    descripcion
    tipo
    fecha_inicio
    fecha_fin
    color
}
entity Anuncio {
    titulo
    contenido
    prioridad
    publicado
    fecha_publicacion
    fecha_expiracion
}
entity LecturaAnuncio {
    fecha_lectura
}

/' ============================================
   RELACIONES (CHEN)
   ============================================ '/

/'-- USUARIO DESEMPENA AREACARGO --'/
Usuario -N- AreaCargo

/'-- USUARIO SE INSCRIBE EN CURSO --'/
relationship INSCRIBE_EN {
}
Usuario -N- INSCRIBE_EN
INSCRIBE_EN -1- InscripcionCurso
InscripcionCurso -1- Curso

/'-- USUARIO CREA CURSO --'/
relationship CREA {
}
Usuario -N- CREA
CREA -1- Curso

/'-- USUARIO COMPLETA CLASE --'/
relationship COMPLETA {
}
Usuario -N- COMPLETA
COMPLETA -1- ClaseCompletado
ClaseCompletado -1- Clase

/'-- USUARIO APRUEBA EVALUACION --'/
relationship APRUEBA {
}
Usuario -N- APRUEBA
APRUEBA -1- IntentoEvaluacion
IntentoEvaluacion -1- Evaluacion

/'-- USUARIO RECIBE CERTIFICADO --'/
relationship RECIBE {
}
Usuario -N- RECIBE
RECIBE -1- Certificado

/'-- USUARIO RECIBE ANUNCIO --'/
relationship RECIBE_AN {
}
Usuario -N- RECIBE_AN
RECIBE_AN -1- LecturaAnuncio
LecturaAnuncio -1- Anuncio

/'-- USUARIO ENTREGA TAREA --'/
relationship ENTREGA {
}
Usuario -N- ENTREGA
ENTREGA -1- EntregaTarea
EntregaTarea -1- Tarea

/'-- USUARIO RECIBE RECORDATORIO --'/
relationship RECIBE_REC {
}
Usuario -N- RECIBE_REC
RECIBE_REC -0- Curso

/'-- CURSO CONTIENE MATERIAL --'/
Curso -N- Material

/'-- CURSO CONTIENE CLASE --'/
Curso -N- Clase

/'-- CURSO TIENE EVALUACION --'/
Curso -N- Evaluacion

/'-- CURSO TIENE TAREA --'/
Curso -N- Tarea

/'-- CURSO GENERA EVENTO CALENDARIO --'/
Curso -N- EventoCalendario

/'-- CURSO PUBLICADO EN CATEGORIA --'/
relationship PUBLICADO_EN {
}
Curso -N- PUBLICADO_EN
PUBLICADO_EN -1- Categoria

/'-- EVALUACION USA BANCO PREGUNTAS --'/
relationship USA_BANCO {
}
Evaluacion -N- USA_BANCO
USA_BANCO -1- BancoPreguntas
Pregunta -0- USA_BANCO
BancoPreguntas -N- Pregunta

/'-- EVALUACION CONTIENE PREGUNTA --'/
Evaluacion -N- Pregunta

/'-- PREGUNTA TIENE ALTERNATIVA --'/
Pregunta -N- Alternativa

/'-- CERTIFICADO EMITIDO POR USUARIO --'/
relationship EMITIDO_POR {
}
Certificado -N- EMITIDO_POR
EMITIDO_POR -1- Usuario

@endchen
