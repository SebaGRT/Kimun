{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 2048,
      "includeFiles": "../**"
    }
  },
  "env": {
    "PYTHON_VERSION": "3.12"
  }
}
