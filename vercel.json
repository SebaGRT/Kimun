{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pip install --break-system-packages -r requirements.txt",
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.py" }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "maxDuration": 30,
      "memory": 2048
    }
  },
  "env": {
    "PYTHON_VERSION": "3.12"
  }
}