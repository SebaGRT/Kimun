{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pip install -r requirements.txt",
  "installCommand": "pip install -r requirements.txt",
  "functions": {
    "api/**/*.py": {
      "maxDuration": 30,
      "memory": 2048
    }
  },
  "env": {
    "PYTHON_VERSION": "3.12"
  }
}