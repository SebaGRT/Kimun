{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "django",
  "buildCommand": "pip install -r requirements.txt",
  "installCommand": "pip install -r requirements.txt",
  "devCommand": "python manage.py runserver",
  "functions": {
    "*.py": {
      "maxDuration": 30,
      "memory": 2048
    }
  },
  "env": {
    "DEBUG": "False",
    "PYTHON_VERSION": "3.12"
  }
}