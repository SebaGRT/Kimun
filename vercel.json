{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "uv pip install --system --break-system-packages -r requirements.txt",
  "pythonVersion": "3.12",
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.12",
      "maxDuration": 30,
      "memory": 2048
    }
  },
  "env": {
    "PYTHON_VERSION": "3.12"
  }
}