{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "yum install -y cairo-devel && uv pip install --system -r requirements.txt",
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 2048
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "env": {
    "DEBUG": "False",
    "PYTHON_VERSION": "3.12"
  }
}
